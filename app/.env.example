# OAuth 2.0 Web client — Client ID is public (exposed to browser)
# Format: xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# 0 = entire mailbox. Set e.g. 500 to cap browser scan.
GMAIL_MAX_MESSAGES=0
GMAIL_CONCURRENCY=12

PORT=3456

# Google Analytics 4. Public by design; empty disables analytics entirely.
# src/lib/config.ts wins over this when it exists (server/load-local-config.js reads it first).
GA_MEASUREMENT_ID=

# Supabase — server-side only (SOW 001 cleanup labels). Never NEXT_PUBLIC_ / never in CSP.
# Apply app/server/sql/001_user_service_choice.sql in the Supabase SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
