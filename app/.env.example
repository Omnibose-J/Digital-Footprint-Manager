# OAuth 2.0 Web client — Client ID is public (exposed to browser)
# Format: xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# 0 = entire mailbox. Set e.g. 500 to cap browser scan.
GMAIL_MAX_MESSAGES=0
GMAIL_CONCURRENCY=12

PORT=3456

# Google Analytics 4. Public by design; empty disables analytics entirely.
# src/lib/config.ts wins over this when it exists (server/load-local-config.js reads it first).
GA_MEASUREMENT_ID=

# Supabase — server-side only (SOW 001/002 cleanup labels). Never NEXT_PUBLIC_ / never in CSP.
# Apply server/sql/001_user_service_choice.sql then 002_completion_timestamps.sql before first use.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini — server-side only, and empty by default on purpose.
#
# /api/classify-senders sends display name + sender address to Google, which PRODUCT_SPEC §3 forbids
# ("never send full sender addresses to the product backend") and §5 forbids again ("do not introduce
# an LLM into discovery"). Setting this key turns that route on: it stops being dead code and starts
# being a live Gemini proxy that checks same-origin and nothing else. See docs/tracking/findings.md.
#
# Leave empty until the spec says otherwise. The scan works without it — the rules are the product.
GEMINI_API_KEY=
