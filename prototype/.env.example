# Google Cloud Console > APIs & Services > Credentials
# Create OAuth client (Desktop app or Web with http://localhost:3456/oauth2callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: CLI-only fallback via `npm run auth`.
# Normal flow: type email in the UI → Google 연결 (no refresh token needed in .env)
GOOGLE_REFRESH_TOKEN=

# 0 = scan entire mailbox (no cap). Set e.g. 500 to limit.
GMAIL_MAX_MESSAGES=0
# Parallel messages.get calls (higher = faster, watch Gmail quota)
GMAIL_CONCURRENCY=12

# Server
PORT=3456
